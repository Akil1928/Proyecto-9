<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cr.ac.ucr.sga.controller.StudentController"
      style="-fx-background-color: #1E2028; -fx-padding: 16;"
      stylesheets="@../css/styless.css">

    <Label text="Expediente Académico"
           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #E8EBF2;"/>

    <!-- Info del estudiante -->
    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-background-color: #272B35; -fx-background-radius: 8;
                 -fx-border-color: #363B48; -fx-border-radius: 8; -fx-padding: 10 14 10 14;">
        <Label text="Estudiante:"
               style="-fx-text-fill: #9AA3B5; -fx-font-size: 13px;"/>
        <Label fx:id="lblNombreEstudiante" text="—"
               style="-fx-font-weight: bold; -fx-text-fill: #E8EBF2; -fx-font-size: 13px;"/>
        <Label text="|"
               style="-fx-text-fill: #363B48; -fx-font-size: 14px;"/>
        <Label text="Créditos aprobados:"
               style="-fx-text-fill: #9AA3B5; -fx-font-size: 13px;"/>
        <Label fx:id="lblCreditosAprobados" text="0"
               style="-fx-font-weight: bold; -fx-text-fill: #F0A500; -fx-font-size: 14px;"/>
    </HBox>

    <!-- Panel admin: formulario de carga de cursos -->
    <VBox fx:id="panelAdminCurso" spacing="10"
          style="-fx-background-color: #272B35; -fx-background-radius: 10;
                 -fx-border-color: #363B48; -fx-border-radius: 10; -fx-padding: 14;">

        <GridPane hgap="12" vgap="10">
            <!-- Fila 0 -->
            <Label text="Código:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                   style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtCode" promptText="Ej: IF3001"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"
                       style="-fx-background-color: #1E2028; -fx-text-fill: #E8EBF2;
                              -fx-prompt-text-fill: #4A5068; -fx-border-color: #363B48;
                              -fx-border-radius: 7; -fx-background-radius: 7; -fx-padding: 7 10 7 10;"/>

            <Label text="Curso:" GridPane.rowIndex="0" GridPane.columnIndex="2"
                   style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtName" promptText="Nombre del curso"
                       GridPane.rowIndex="0" GridPane.columnIndex="3"
                       style="-fx-background-color: #1E2028; -fx-text-fill: #E8EBF2;
                              -fx-prompt-text-fill: #4A5068; -fx-border-color: #363B48;
                              -fx-border-radius: 7; -fx-background-radius: 7; -fx-padding: 7 10 7 10;"/>

            <!-- Fila 1 -->
            <Label text="Créditos:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                   style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtCredits" promptText="Ej: 4"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"
                       style="-fx-background-color: #1E2028; -fx-text-fill: #E8EBF2;
                              -fx-prompt-text-fill: #4A5068; -fx-border-color: #363B48;
                              -fx-border-radius: 7; -fx-background-radius: 7; -fx-padding: 7 10 7 10;"/>

            <Label text="Nota:" GridPane.rowIndex="1" GridPane.columnIndex="2"
                   style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtGrade" promptText="0 – 100"
                       GridPane.rowIndex="1" GridPane.columnIndex="3"
                       style="-fx-background-color: #1E2028; -fx-text-fill: #E8EBF2;
                              -fx-prompt-text-fill: #4A5068; -fx-border-color: #363B48;
                              -fx-border-radius: 7; -fx-background-radius: 7; -fx-padding: 7 10 7 10;"/>

            <!-- Fila 2 -->
            <Label text="Periodo:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                   style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <ComboBox fx:id="cbPeriod" GridPane.rowIndex="2" GridPane.columnIndex="1"
                      style="-fx-background-color: #1E2028; -fx-border-color: #363B48;
                             -fx-border-radius: 7; -fx-background-radius: 7;"/>

            <Label text="Estado:" GridPane.rowIndex="2" GridPane.columnIndex="2"
                   style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <ComboBox fx:id="cbStatus" GridPane.rowIndex="2" GridPane.columnIndex="3"
                      style="-fx-background-color: #1E2028; -fx-border-color: #363B48;
                             -fx-border-radius: 7; -fx-background-radius: 7;"/>
        </GridPane>

        <HBox spacing="10">
            <Button text="Agregar curso"         styleClass="btn-primary" onAction="#addCourse"/>
            <Button text="Eliminar seleccionado" styleClass="btn-green"   onAction="#deleteSelectedCourse"/>
            <Button fx:id="btnLoadDemo" text="Cargar 3 cursos de demo" styleClass="btn-ghost" onAction="#addDemoCourses"/>
        </HBox>
    </VBox>

    <!-- Tabla -->
    <TableView fx:id="tableRecord" prefHeight="320" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #272B35; -fx-border-color: #363B48;
                      -fx-border-radius: 10; -fx-background-radius: 10;
                      -fx-table-cell-border-color: transparent;">
        <columns>
            <TableColumn fx:id="colCode"    text="Código"   prefWidth="90"/>
            <TableColumn fx:id="colName"    text="Curso"    prefWidth="260"/>
            <TableColumn fx:id="colPeriod"  text="Periodo"  prefWidth="90"/>
            <TableColumn fx:id="colCredits" text="Créditos" prefWidth="80"/>
            <TableColumn fx:id="colGrade"   text="Nota"     prefWidth="70"/>
            <TableColumn fx:id="colStatus"  text="Estado"   prefWidth="110"/>
        </columns>
        <placeholder>
            <Label text="No hay registros en el expediente"
                   style="-fx-text-fill: #4A5068;"/>
        </placeholder>
    </TableView>

    <Label fx:id="lblStatus" text="Listo."
           style="-fx-text-fill: #6B7280; -fx-font-size: 11px; -fx-font-style: italic;"/>

</VBox>
