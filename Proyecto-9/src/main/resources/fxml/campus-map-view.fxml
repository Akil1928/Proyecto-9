<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="cr.ac.ucr.sga.controller.CampusMapController"
      style="-fx-background-color: #1E2028; -fx-padding: 16;"
      stylesheets="@../css/styless.css">

    <Label text="Mapa del Campus - Navegación de Edificios"
           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #E8EBF2;"/>

    <!-- Canvas para mostrar el mapa -->
    <ScrollPane fitToWidth="false" fitToHeight="false" pannable="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: #1E2028; -fx-border-color: #363B48; -fx-border-radius: 8;">
        <Canvas fx:id="canvas" width="900" height="600" style="-fx-cursor: hand;"/>
    </ScrollPane>

    <!-- Controles de Administrador (solo visible para admin) -->
    <VBox fx:id="adminControlsPanel" spacing="10"
          style="-fx-background-color: #272B35; -fx-background-radius: 8;
                 -fx-border-color: #363B48; -fx-border-radius: 8; -fx-padding: 12 14 12 14;">

        <!-- Algoritmo: Dijkstra -->
        <Label text="Dijkstra - Ruta Más Corta"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #E8EBF2;"/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Origen:" style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px;"/>
            <ComboBox fx:id="cbOrigin" prefWidth="200"
                      style="-fx-background-color: #1E2028; -fx-text-fill: #E8EBF2;
                             -fx-border-color: #363B48; -fx-border-radius: 6;"/>
            <Label text="Destino:" style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px;"/>
            <ComboBox fx:id="cbDestination" prefWidth="200"
                      style="-fx-background-color: #1E2028; -fx-text-fill: #E8EBF2;
                             -fx-border-color: #363B48; -fx-border-radius: 6;"/>
            <Button fx:id="btnDijkstra" text="Ejecutar Dijkstra" styleClass="btn-primary" onAction="#onDijkstra"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label fx:id="lblDistance" text="" style="-fx-text-fill: #9AA3B5; -fx-font-size: 12px;"/>
            <Label fx:id="lblPath" text="" style="-fx-text-fill: #9AA3B5; -fx-font-size: 12px;"/>
        </HBox>

        <!-- Recorridos: BFS y DFS -->
        <Label text="Recorridos - BFS y DFS"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #E8EBF2;"/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button fx:id="btnBFS" text="Iniciar BFS" styleClass="btn-ghost" onAction="#onBFS"/>
            <Button fx:id="btnDFS" text="Iniciar DFS" styleClass="btn-ghost" onAction="#onDFS"/>
            <Button fx:id="btnStep" text="Paso" styleClass="btn-ghost" onAction="#onStep"/>
            <Button fx:id="btnAutoPlay" text="Reproducir Animación" styleClass="btn-ghost" onAction="#onAutoPlay"/>
            <Button fx:id="btnReset" text="Reiniciar" styleClass="btn-ghost" onAction="#onReset"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label fx:id="lblAlgorithm" text="" style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px;"/>
        </HBox>

        <!-- Exportación de reportes -->
        <Separator style="-fx-opacity: 0.4;"/>
        <Label text="Exportar Reportes"
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #E8EBF2;"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="Generar Reporte Métricas" styleClass="btn-ghost" onAction="#onExportMetricsReport"/>
            <Button text="Generar Reporte Ruta Actual" styleClass="btn-ghost" onAction="#onExportPathReport"/>
        </HBox>
    </VBox>

    <!-- Leyenda -->
    <HBox spacing="20" alignment="CENTER_LEFT"
          style="-fx-background-color: #272B35; -fx-background-radius: 8;
                 -fx-border-color: #363B48; -fx-border-radius: 8; -fx-padding: 8 14 8 14;">
        <Label text="🔵 Edificio (no visitado)"
               style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px;"/>
        <Label text="🟢 Visitado"
               style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px;"/>
        <Label text="🟡 Nodo actual"
               style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px;"/>
        <Label text="🟠 En ruta óptima"
               style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px;"/>
        <Label text="━━ Distancia (metros)"
               style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px;"/>
    </HBox>

    <!-- Status bar -->
    <Label fx:id="lblStatus"
           text="✔ Mapa del campus cargado correctamente."
           style="-fx-text-fill: #9AA3B5; -fx-font-size: 12px; -fx-font-style: italic;"/>

</VBox>

