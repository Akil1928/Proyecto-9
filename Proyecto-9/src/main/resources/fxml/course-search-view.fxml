<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="cr.ac.ucr.sga.controller.CourseSearchController"
      styleClass="panel"
      stylesheets="@../css/styless.css">

    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <Label text="Búsqueda Eficiente de Cursos (BST)" styleClass="panel-title"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Código a buscar:"/>
        <TextField fx:id="txtSearchCode" promptText="Ej: IF-0010" prefWidth="160"/>
        <Button text="Buscar" styleClass="btn-primary" onAction="#onBuscar"/>
        <Button text="Reconstruir árbol" styleClass="btn-ghost" onAction="#onReconstruir"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblInfo" text="Cursos: 0  |  Altura: 0"/>
    </HBox>

    <ScrollPane fitToWidth="true" fitToHeight="false" VBox.vgrow="ALWAYS">
        <Canvas fx:id="canvas" width="1100" height="600"/>
    </ScrollPane>

    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="info-bar">
        <padding><Insets top="6" right="10" bottom="6" left="10"/></padding>
        <Label text="⬜ Curso"/>
        <Label text="🟥 Nodo comparado durante la búsqueda"/>
        <Label text="🟩 Curso encontrado"/>
    </HBox>

    <Label fx:id="lblStatus" text="Listo. Ingrese un código y presione &quot;Buscar&quot;." styleClass="status-bar"/>

</VBox>