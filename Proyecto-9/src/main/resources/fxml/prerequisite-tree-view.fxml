<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="cr.ac.ucr.sga.controller.PrerequisiteTreeController"
      styleClass="panel"
      stylesheets="@../css/styless.css">

    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <Label text="Árbol de Prerrequisitos" styleClass="panel-title"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Código de curso:"
               style="-fx-text-fill: #C8CDD8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        <TextField fx:id="txtCourseCode" promptText="Ej: IF-0010" prefWidth="160"/>
        <Button text="Buscar" styleClass="btn-primary" onAction="#onBuscar"/>
    </HBox>

    <ScrollPane fitToWidth="false" fitToHeight="false" pannable="true" VBox.vgrow="ALWAYS">
        <Canvas fx:id="canvas" width="1100" height="500"/>
    </ScrollPane>

    <!-- Leyenda -->
    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="info-bar">
        <Label text="🟩 Curso consultado"
               style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px;"/>
        <Label text="⬜ Prerrequisito"
               style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px;"/>
        <Label text="🟨 Alternativas (uno de los cursos del grupo)"
               style="-fx-text-fill: #C8CDD8; -fx-font-size: 12px;"/>
    </HBox>

    <Label fx:id="lblStatus"
           text="Listo. Ingrese un código y presione &quot;Buscar&quot;."
           style="-fx-text-fill: #9AA3B5; -fx-font-size: 12px; -fx-font-style: italic;"/>

</VBox>
